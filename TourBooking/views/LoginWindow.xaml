<Window x:Class="TourBooking.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng nhập hệ thống" Height="650" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F9"
        FontFamily="Segoe UI">

    <Border CornerRadius="12" Margin="40" Background="White">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#D0D5DD" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4.5*"/>
                <ColumnDefinition Width="5.5*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#1D3D8F" CornerRadius="12,0,0,12" Padding="40">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A2,2 0 0,1 14,6A2,2 0 0,1 12,8A2,2 0 0,1 10,6A2,2 0 0,1 12,4M12,18C8.67,18 6,15.33 6,12C6,10.1 6.88,8.4 8.26,7.28L9.68,8.7C8.64,9.5 8,10.67 8,12C8,14.2 9.8,16 12,16C14.2,16 16,14.2 16,12C16,10.67 15.36,9.5 14.32,8.7L15.74,7.28C17.12,8.4 18,10.1 18,12C18,15.33 15.33,18 12,18Z" 
                              Fill="White" Width="24" Height="24" Margin="0,0,10,0"/>
                        <TextBlock Text="Net Tour Booking" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,0,20,0">
                        <TextBlock Text="Giải pháp quản lý du lịch&#x0a;chuyên nghiệp" 
                                   Foreground="White" FontSize="28" FontWeight="Bold" TextWrapping="Wrap" LineHeight="36"/>
                        <TextBlock Text="Hệ thống quản lý vận tải và tour tích hợp, tối ưu hóa quy trình vận hành cho doanh nghiệp lữ hành hiện đại." 
                                   Foreground="#A3B8CC" FontSize="14" Margin="0,20,0,0" TextWrapping="Wrap" LineHeight="22"/>
                    </StackPanel>

                    <UniformGrid Grid.Row="2" Columns="2" Rows="1" Margin="0,0,0,10">
                        <Border BorderBrush="#3A5AA6" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,8,0" Background="#2448A4">
                            <StackPanel>
                                <TextBlock Text="Hệ thống ổn định" Foreground="#A3B8CC" FontSize="12" Margin="0,0,0,4"/>
                                <TextBlock Text="99.9% Uptime" Foreground="White" FontSize="14" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                        <Border BorderBrush="#3A5AA6" BorderThickness="1" CornerRadius="6" Padding="12" Margin="8,0,0,0" Background="#2448A4">
                            <StackPanel>
                                <TextBlock Text="Bảo mật" Foreground="#A3B8CC" FontSize="12" Margin="0,0,0,4"/>
                                <TextBlock Text="AES-256 Encrypted" Foreground="White" FontSize="14" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="60,40,60,40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,20,0,30">
                    <TextBlock Text="Đăng nhập hệ thống" FontSize="28" FontWeight="Bold" Foreground="#101828"/>
                    <TextBlock Text="Vui lòng nhập thông tin tài khoản quản trị để tiếp tục." FontSize="14" Foreground="#667085" Margin="0,8,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,0,0,16">
                    <TextBlock Text="TÊN ĐĂNG NHẬP / EMAIL" FontSize="12" FontWeight="SemiBold" Foreground="#344054" Margin="0,0,0,6"/>
                    <Grid>
                        <TextBox x:Name="txtUsername" Text="" Padding="35,10,10,10" FontSize="14" Foreground="#101828" BorderBrush="#D0D5DD" Height="42">
                            <TextBox.Resources>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                        <Path Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z" 
                              Fill="#667085" Width="16" Height="16" HorizontalAlignment="Left" Margin="12,0,0,0"/>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="0,0,0,20">
                    <TextBlock Text="MẬT KHẨU" FontSize="12" FontWeight="SemiBold" Foreground="#344054" Margin="0,0,0,6"/>
                    <Grid>
                        <PasswordBox x:Name="txtPassword" Padding="35,10,35,10" FontSize="14" Foreground="#101828" BorderBrush="#D0D5DD" Height="42">
                            <PasswordBox.Resources>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </PasswordBox.Resources>
                        </PasswordBox>
                        <Path Data="M12,17A2,2 0 0,0 14,15C14,13.89 13.1,13 12,13A2,2 0 0,0 10,15A2,2 0 0,0 12,17M18,8A2,2 0 0,1 20,10V20A2,2 0 0,1 18,22H6A2,2 0 0,1 4,20V10A2,2 0 0,1 6,8H7V6A5,5 0 0,1 12,1A5,5 0 0,1 17,6V8H18M12,3A3,3 0 0,0 9,6V8H15V6A3,3 0 0,0 12,3Z" 
                              Fill="#667085" Width="16" Height="16" HorizontalAlignment="Left" Margin="12,0,0,0"/>
                        <Button Background="Transparent" BorderBrush="Transparent" HorizontalAlignment="Right" Margin="0,0,10,0" Cursor="Hand">
                            <Path Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z" 
                                  Fill="#667085" Width="18" Height="18"/>
                        </Button>
                    </Grid>
                </StackPanel>

                <Grid Grid.Row="3" Margin="0,0,0,24">
                    <CheckBox Content="Ghi nhớ đăng nhập" FontSize="14" Foreground="#344054" VerticalContentAlignment="Center"/>
                    <TextBlock Text="Quên mật khẩu?" FontSize="14" FontWeight="SemiBold" Foreground="#1D3D8F" HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand"/>
                </Grid>

                <Button Grid.Row="4" Click="BtnLogin_Click" Background="#1D3D8F" Foreground="White" Height="45" FontSize="14" FontWeight="Bold" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="ĐĂNG NHẬP HỆ THỐNG" VerticalAlignment="Center"/>
                        <Path Data="M14,16.58L15.42,18L21.42,12L15.42,6L14,7.42L17.58,11H3V13H17.58L14,16.58Z" 
                              Fill="White" Width="16" Height="16" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Border Grid.Row="6" Background="#F8F9FA" CornerRadius="8" Padding="16" Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0" Data="M11,15H13V17H11V15M11,7H13V13H11V7M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4Z" 
                              Fill="#F79009" Width="18" Height="18" VerticalAlignment="Top" Margin="0,2,10,0"/>
                        <TextBlock Grid.Column="1" FontSize="13" Foreground="#344054" TextWrapping="Wrap" LineHeight="18">
                            Nếu gặp sự cố truy cập hoặc quên thông tin tài khoản, vui lòng liên hệ <Run FontWeight="Bold" Foreground="#101828">Bộ phận Admin kỹ thuật</Run> hoặc gửi email về <Run Foreground="#1D3D8F" TextDecorations="Underline">support@nettour.vn</Run>.
                        </TextBlock>
                    </Grid>
                </Border>

                <TextBlock Grid.Row="7" Text="© 2024 Net Tour Booking Enterprise. All rights reserved." FontSize="12" Foreground="#667085" HorizontalAlignment="Left"/>
            </Grid>
        </Grid>
    </Border>
</Window>